  "private": true,
  "devDependencies": {
    "openclaw": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.26"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "hooks": {
      "agent_bootstrap": "./src/workspace-loader.ts"
    }
  }
}
