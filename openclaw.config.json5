// ARI × OpenClaw Configuration
// OpenClaw config for Pryce Hedrick's personal ARI build
// See docs/ARI_ENV_COMPLETE.md for all env variables
{
  // Gateway settings
  gateway: {
    port: 3141,
    bind: "127.0.0.1",   // Loopback only — NEVER 0.0.0.0 (security invariant #1)
    auth: {
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  // ARI plugins (explicit allowlist + config-path discovery)
  plugins: {
    enabled: true,
    load: {
      paths: [
        "plugins",
      ],
    },
    allow: [
      "ari-kernel",
      "ari-cognitive",
      "ari-workspace",
      "ari-ai",
      "ari-memory",
      "ari-scheduler",
      "ari-briefings",
      "ari-market",
      "ari-governance",
      "ari-agents",
      "ari-autonomous",
      "ari-notion",
      "ari-voice",
    ],
    entries: {
      "ari-kernel": { enabled: true },
      "ari-cognitive": { enabled: true },
      "ari-workspace": { enabled: true },
      "ari-ai": { enabled: true },
      "ari-memory": { enabled: true },
      "ari-scheduler": { enabled: true },
      "ari-briefings": { enabled: true },
      "ari-market": { enabled: true },
      "ari-governance": { enabled: true },
      "ari-agents": { enabled: true },
      "ari-autonomous": {
        enabled: true,
        config: {
          apiBaseUrl: "${ARI_PIPELINES_API_BASE_URL:-http://127.0.0.1:8787}",
          apiToken: "${ARI_PIPELINES_API_TOKEN}",
          timeoutMs: "${ARI_PIPELINES_API_TIMEOUT_MS:-20000}",
          retry: {
            attempts: "${ARI_PIPELINES_API_RETRY_ATTEMPTS:-3}",
            mutationAttempts: "${ARI_PIPELINES_API_RETRY_MUTATION_ATTEMPTS:-1}",
            approvalAttempts: "${ARI_PIPELINES_API_RETRY_APPROVAL_ATTEMPTS:-1}",
            minDelayMs: "${ARI_PIPELINES_API_RETRY_MIN_DELAY_MS:-350}",
            maxDelayMs: "${ARI_PIPELINES_API_RETRY_MAX_DELAY_MS:-3000}",
            statusCodes: "${ARI_PIPELINES_API_RETRY_STATUS_CODES:-408,425,429,500,502,503,504}",
          },
          opsAutopublish: {
            enabled: "${ARI_OPS_AUTOPUBLISH_ENABLED:-false}",
            intervalMinutes: "${ARI_OPS_AUTOPUBLISH_INTERVAL_MINUTES:-180}",
            windowHours: "${ARI_OPS_AUTOPUBLISH_WINDOW_HOURS:-24}",
            startupDelaySeconds: "${ARI_OPS_AUTOPUBLISH_STARTUP_DELAY_SECONDS:-45}",
            force: "${ARI_OPS_AUTOPUBLISH_FORCE:-false}",
            businessUnit: "${ARI_OPS_AUTOPUBLISH_BUSINESS_UNIT:-operations}",
            channelId: "${ARI_OPS_AUTOPUBLISH_CHANNEL_ID:-${ARI_DISCORD_CHANNEL_SYSTEM_STATUS}}",
            failureAlertThreshold: "${ARI_OPS_AUTOPUBLISH_FAILURE_ALERT_THRESHOLD:-3}",
            failureAlertCooldownMinutes: "${ARI_OPS_AUTOPUBLISH_FAILURE_ALERT_COOLDOWN_MINUTES:-120}",
          },
          opsCanary: {
            enabled: "${ARI_OPS_CANARY_ENABLED:-false}",
            intervalMinutes: "${ARI_OPS_CANARY_INTERVAL_MINUTES:-1440}",
            startupDelaySeconds: "${ARI_OPS_CANARY_STARTUP_DELAY_SECONDS:-90}",
            severity: "${ARI_OPS_CANARY_SEVERITY:-warning}",
            source: "${ARI_OPS_CANARY_SOURCE:-ops.canary}",
            message: "${ARI_OPS_CANARY_MESSAGE:-synthetic canary escalation check}",
            businessUnit: "${ARI_OPS_CANARY_BUSINESS_UNIT:-operations}",
            channelId: "${ARI_OPS_CANARY_CHANNEL_ID:-${ARI_DISCORD_CHANNEL_SYSTEM_STATUS}}",
          },
          opsWeeklyDigest: {
            enabled: "${ARI_OPS_WEEKLY_DIGEST_AUTOPUBLISH_ENABLED:-false}",
            intervalMinutes: "${ARI_OPS_WEEKLY_DIGEST_AUTOPUBLISH_INTERVAL_MINUTES:-10080}",
            windowHours: "${ARI_OPS_WEEKLY_DIGEST_AUTOPUBLISH_WINDOW_HOURS:-168}",
            startupDelaySeconds: "${ARI_OPS_WEEKLY_DIGEST_AUTOPUBLISH_STARTUP_DELAY_SECONDS:-120}",
            failureAlertThreshold: "${ARI_OPS_WEEKLY_DIGEST_FAILURE_ALERT_THRESHOLD:-2}",
            failureAlertCooldownMinutes: "${ARI_OPS_WEEKLY_DIGEST_FAILURE_ALERT_COOLDOWN_MINUTES:-720}",
            forceRerunEnabled: "${ARI_OPS_WEEKLY_DIGEST_FORCE_RERUN_ENABLED:-true}",
            forceRerunDelayMinutes: "${ARI_OPS_WEEKLY_DIGEST_FORCE_RERUN_DELAY_MINUTES:-30}",
            forceRerunMaxAttempts: "${ARI_OPS_WEEKLY_DIGEST_FORCE_RERUN_MAX_ATTEMPTS:-1}",
          },
          routing: {
            strict: true,
            p1ChannelIds: [
              "${ARI_DISCORD_CHANNEL_MAIN}",
              "${ARI_DISCORD_CHANNEL_DEEP}",
              "${ARI_DISCORD_CHANNEL_MARKET_ALERTS}",
              "${ARI_DISCORD_CHANNEL_POKEMON}",
              "${ARI_DISCORD_CHANNEL_PAYTHEPRICE}",
              "${ARI_DISCORD_CHANNEL_THUMBNAIL_LAB}",
            ],
            p2ChannelIds: [
              "${ARI_DISCORD_CHANNEL_MAIN}",
              "${ARI_DISCORD_CHANNEL_DEEP}",
              "${ARI_DISCORD_CHANNEL_LEADS}",
              "${ARI_DISCORD_CHANNEL_BATTLE_PLANS}",
              "${ARI_DISCORD_CHANNEL_DEMO_FACTORY}",
              "${ARI_DISCORD_CHANNEL_OUTREACH_QUEUE}",
            ],
            statusChannelIds: [
              "${ARI_DISCORD_CHANNEL_MAIN}",
              "${ARI_DISCORD_CHANNEL_SYSTEM_STATUS}",
            ],
          },
        },
      },
      "ari-notion": { enabled: true },
      "ari-voice": { enabled: true },
    },
  },

  // Discord — sole channel (no Telegram in ARI)
  channels: {
    discord: {
      token: "${DISCORD_BOT_TOKEN}",
      guildId: "${DISCORD_GUILD_ID}",
      // Allow bot to respond without @mention; restrict to ARI's guild only
      groupPolicy: "open",
      guilds: [{
        id: "${DISCORD_GUILD_ID}",
        requireMention: false,
        users: ["${PRYCE_USER_ID}"],
      }],
    },
  },

  // Agent routing (channel → agent → model)
  agents: {
    routing: [
      // Most specific rules first
      { channel: "${ARI_DISCORD_CHANNEL_DEEP}", agent: "deep-analysis" },
      { channel: "${ARI_DISCORD_CHANNEL_MARKET_ALERTS}", agent: "market-monitor" },
      { channel: "${ARI_DISCORD_CHANNEL_POKEMON}", agent: "market-monitor" },
      { channel: "${ARI_DISCORD_CHANNEL_LEADS}", agent: "growth-pod" },
      { channel: "${ARI_DISCORD_CHANNEL_BATTLE_PLANS}", agent: "growth-pod" },
      // Default: all others → main agent
      { channel: "*", agent: "main" },
    ],

    definitions: {
      "main": {
        model: "claude-sonnet-4-6",
        provider: "anthropic",
        contextTokens: 100000,
        timeoutSeconds: 120,
      },
      "deep-analysis": {
        model: "claude-opus-4-6",
        provider: "anthropic",
        contextTokens: 200000,
        timeoutSeconds: 600,
        // Pre-process with: bayesian_update, expected_value, detect_bias, synthesize
      },
      "market-monitor": {
        model: "claude-haiku-4-5-20251001",
        provider: "anthropic",
        contextTokens: 32000,
        timeoutSeconds: 30,
      },
      "growth-pod": {
        // Model varies by channel — set per-routing entry if needed
        model: "claude-sonnet-4-6",
        provider: "anthropic",
        contextTokens: 50000,
        timeoutSeconds: 120,
      },
      "code-pod": {
        // OpenAI Codex subscription (OAuth, no API key required)
        // Falls back to openai provider if codex auth not active
        model: "gpt-5.3-codex",
        provider: "openai-codex",
        contextTokens: 100000,
        timeoutSeconds: 120,
      },
    },
  },

  // Cost circuit breaker (ModelExecutionPolicy — Phase 1)
  budget: {
    dailyLimitUsd: "${ARI_DAILY_BUDGET_USD:-2.00}",
    fallbackModel: "claude-haiku-4-5-20251001",
    pauseNonEssentialAtPercent: 95,
  },

  // Workspace files (loaded by ari-workspace plugin on agent bootstrap)
  workspace: {
    path: "${ARI_WORKSPACE_PATH:-~/.openclaw/workspace}",
    files: [
      "SOUL.md",
      "USER.md",
      "HEARTBEAT.md",
      "AGENTS.md",
      "RECOVERY.md",
      "GOALS.md",
    ],
  },

  // SQLite databases (ari-memory plugin)
  storage: {
    dbPath: "${ARI_DB_PATH:-~/.ari/databases}",
    walMode: true,
    backupPath: "~/.ari/backup",
  },

  // Cron scheduler (ari-scheduler plugin) — all times ET
  // Canonical task definitions live in plugins/ari-scheduler/index.ts
  scheduler: {
    timezone: "${ARI_TIMEZONE:-America/New_York}",
  },

  // P0 alert channel routing (heartbeat monitor)
  alerts: {
    p0Channel: "${ARI_DISCORD_CHANNEL_MARKET_ALERTS}",
    p1Channel: "${ARI_DISCORD_CHANNEL_PAYTHEPRICE}",
    systemChannel: "${ARI_DISCORD_CHANNEL_SYSTEM_STATUS}",
    mentionUserId: "${PRYCE_USER_ID}",
  },
}
