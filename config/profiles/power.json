{
  "profile": "power",
  "description": "Power profile — deep auto-capture, EOD briefs, daily repo scan, Jina news if key set",
  "obsidian": {
    "enabled": true,
    "autoCapture": {
      "enabled": true,
      "mode": "structured",
      "minSignalScore": 5
    },
    "schedule": {
      "morningDigest": true,
      "weeklyVaultScan": true,
      "vaultCompaction": true
    }
  },
  "finance": {
    "enabled": true,
    "newsProvider": "jina",
    "briefOnMarketEvent": true,
    "eodBrief": true
  },
  "repoScan": {
    "frequency": "daily",
    "mode": "deep"
  },
  "tracing": {
    "mode": "standard"
  },
  "budget": {
    "trackTokens": true,
    "warnAt": 0.8
  }
}
