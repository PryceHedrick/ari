{
  "profile": "forensic",
  "description": "Forensic profile — verbose tracing, all features — requires Safety Gate approval",
  "safetyGate": "required",
  "obsidian": {
    "enabled": true,
    "autoCapture": {
      "enabled": true,
      "mode": "forensic",
      "minSignalScore": 3
    },
    "schedule": {
      "morningDigest": true,
      "weeklyVaultScan": true,
      "vaultCompaction": true
    }
  },
  "finance": {
    "enabled": true,
    "newsProvider": "jina",
    "briefOnMarketEvent": true,
    "eodBrief": true
  },
  "repoScan": {
    "frequency": "daily",
    "mode": "deep"
  },
  "tracing": {
    "mode": "verbose"
  },
  "budget": {
    "trackTokens": true,
    "warnAt": 0.7
  }
}
