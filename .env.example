# ARI × OpenClaw .env
# See docs/ARI_ENV_COMPLETE.md for full documentation of every variable.
#
# Quick start:
# 1) Copy to ~/.openclaw/.env
# 2) Fill in API keys below
# 3) NEVER commit real secrets

# OpenClaw .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.openclaw/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in openclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# =============================================================================
# ARI-SPECIFIC VARIABLES (added by PryceHedrick/ari fork)
# =============================================================================

# -----------------------------------------------------------------------------
# Primary AI — Anthropic (direct API, no proxy)
# ARI uses Anthropic as the primary provider; OpenRouter is NOT required.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Secondary: OpenAI (API key path or Codex OAuth subscription)
# For Codex subscription (no key): openclaw models auth login --provider openai-codex
# OPENAI_API_KEY=sk-...

# Optional additional providers
# XAI_API_KEY=...              # xAI/Grok (PULSE x-sentiment, native X/Twitter data)
# GEMINI_API_KEY=...           # Gemini models via direct API — REQUIRED for PULSE default
#                              # OpenClaw reads GEMINI_API_KEY (not GOOGLE_AI_API_KEY) for provider: "google"
#                              # If you have GOOGLE_AI_API_KEY set, also add GEMINI_API_KEY= (same value, keep both)
# GOOGLE_AI_API_KEY=...        # Legacy — keep existing (other tools may read it), do NOT remove
# PERPLEXITY_API_KEY=pplx-...  # DEX research synthesis (REQUIRED for web search)

# Firecrawl — content extraction for web_fetch (bot circumvention, JS-heavy/protected sites)
# Auto-activates when set; code already wired in web-fetch tool
# FIRECRAWL_API_KEY=

# Brave Search — NOT needed (Perplexity pos-4 covers web search; xAI pos-5 as fallback)
# BRAVE_API_KEY=

# Apify — NOT needed (Firecrawl + Playwright + direct APIs cover all ARI use cases)
# APIFY_API_KEY=

# -----------------------------------------------------------------------------
# Discord (sole channel — no Telegram in ARI)
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
PRYCE_USER_ID=                 # Your Discord user ID (for @mentions + P0 alerts)

# ARI channel IDs — all 19 channels (numeric Discord snowflake IDs)
# Run: bun scripts/discord-check.ts to verify all are set correctly
ARI_DISCORD_CHANNEL_MAIN=
ARI_DISCORD_CHANNEL_DEEP=
ARI_DISCORD_CHANNEL_MARKET_ALERTS=
ARI_DISCORD_CHANNEL_POKEMON=
ARI_DISCORD_CHANNEL_PAYTHEPRICE=
ARI_DISCORD_CHANNEL_THUMBNAIL_LAB=
ARI_DISCORD_CHANNEL_LEADS=
ARI_DISCORD_CHANNEL_BATTLE_PLANS=
ARI_DISCORD_CHANNEL_DEMO_FACTORY=
ARI_DISCORD_CHANNEL_OUTREACH_QUEUE=
ARI_DISCORD_CHANNEL_RESEARCH=
ARI_DISCORD_CHANNEL_SYSTEM_STATUS=
ARI_DISCORD_CHANNEL_OPS_DASHBOARD=
ARI_DISCORD_CHANNEL_VIDEO_QUEUE=
ARI_DISCORD_CHANNEL_SELF_HEALING=
ARI_DISCORD_CHANNEL_RESEARCH_DIGEST=
ARI_DISCORD_CHANNEL_API_LOGS=       # API trace logs (ops:trace_log events)
ARI_DISCORD_CHANNEL_WINS=           # Win logging (ops:win_logged events)
ARI_DISCORD_CHANNEL_PUBLISHED=      # Published content (pipeline:published events)

# -----------------------------------------------------------------------------
# Market data
# -----------------------------------------------------------------------------
# COINGECKO_API_KEY=            # Pro key (free tier works without it)
# ALPHA_VANTAGE_API_KEY=        # Stock data (replaces Finnhub)
# POKEMON_TCG_API_KEY=          # https://pokemontcg.io

# -----------------------------------------------------------------------------
# Voice briefings (ElevenLabs)
# Plugin fully implemented — enable to get native Discord voice messages after each briefing
# -----------------------------------------------------------------------------
# ELEVENLABS_API_KEY=           # Required for audio briefings
# ELEVENLABS_VOICE_ID=          # ARI's voice ID
# ARI_VOICE_ENABLED=true        # Recommend: true (keys present, ~$0.50/day)
# ARI_ELEVENLABS_V3_ENABLED=true  # Recommend: true (eleven_v3 model = higher quality)
# ARI_VOICE_CHANNEL_ENABLED=false # Defer: routes to live voice channel (requires ARI_DISCORD_VOICE_CHANNEL_ID)
# ARI_DISCORD_VOICE_CHANNEL_ID=   # Optional: Discord voice channel snowflake

# -----------------------------------------------------------------------------
# Integrations
# -----------------------------------------------------------------------------
# NOTION_API_KEY=               # For journal + notes (ari-notion plugin)
# TAVILY_API_KEY=               # Web search
# WEATHER_API_KEY=              # Briefing weather data
# GITHUB_TOKEN=                 # Repo operations

# Gmail (OAuth credentials)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# Reddit (authenticated snoowrap — optional; public feeds work without it)
# REDDIT_USER_AGENT=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# X (Twitter) API — read-only intel (gated by ARI_ENABLE_X_INTEL)
# App-only bearer token; no user OAuth required for read-only access
# -----------------------------------------------------------------------------
# ARI_ENABLE_X_INTEL=true        # Recommend: true (key present, read-only, no cost)
#                                # Set to true to enable DEX's x-likes-digest at 20:00 ET
# X_BEARER_TOKEN=                # App-only bearer for read-only search/timeline
# X_INTEL_KEYWORDS=crypto,pokemon,AI,pryceless  # Comma-separated search terms

# -----------------------------------------------------------------------------
# ARI system settings
# -----------------------------------------------------------------------------
# ARI_DAILY_BUDGET_USD=2.00     # Cost circuit breaker limit
# ARI_TIMEZONE=America/New_York # All cron runs in ET
# ARI_DB_PATH=~/.ari/databases  # SQLite WAL databases
# ARI_WORKSPACE_PATH=~/.openclaw/workspace  # Identity workspace files
