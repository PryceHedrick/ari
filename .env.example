# ARI × OpenClaw .env
# See docs/ARI_ENV_COMPLETE.md for full documentation of every variable.
#
# Quick start:
# 1) Copy to ~/.openclaw/.env
# 2) Fill in API keys below
# 3) NEVER commit real secrets

# OpenClaw .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.openclaw/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in openclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# =============================================================================
# ARI-SPECIFIC VARIABLES (added by PryceHedrick/ari fork)
# =============================================================================

# -----------------------------------------------------------------------------
# Primary AI routing (ARI uses OpenRouter as gateway)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...
# PERPLEXITY_API_KEY=pplx-...  # Direct only — never proxied through OpenRouter
# GOOGLE_AI_API_KEY=...        # For Gemini models via direct API

# -----------------------------------------------------------------------------
# Discord (sole channel — no Telegram in ARI)
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# ARI channel IDs (from your Discord server)
# ARI_DISCORD_CHANNEL_MAIN=
# ARI_DISCORD_CHANNEL_DEEP=
# ARI_DISCORD_CHANNEL_PORTFOLIO=
# ARI_DISCORD_CHANNEL_POKEMON=
# ARI_DISCORD_CHANNEL_LEADS=
# ARI_DISCORD_CHANNEL_BATTLE_PLANS=
# ARI_DISCORD_CHANNEL_MARKET_ALERTS=
# ARI_DISCORD_CHANNEL_EVENING_SUMMARY=
# ARI_DISCORD_CHANNEL_SYSTEM_STATUS=
# PRYCE_USER_ID=  # Your Discord user ID (for @mentions)

# -----------------------------------------------------------------------------
# Market data
# -----------------------------------------------------------------------------
# COINGECKO_API_KEY=            # Pro key (free tier works too)
# ALPHA_VANTAGE_API_KEY=
# POKEMON_TCG_API_KEY=          # https://pokemontcg.io

# -----------------------------------------------------------------------------
# Voice briefings (ElevenLabs)
# -----------------------------------------------------------------------------
# ELEVENLABS_API_KEY=           # Required for audio briefings
# ELEVENLABS_VOICE_ID=          # ARI's voice ID

# -----------------------------------------------------------------------------
# Integrations
# -----------------------------------------------------------------------------
# NOTION_API_KEY=               # For journal + notes (ari-notion plugin)
# TAVILY_API_KEY=               # Web search
# WEATHER_API_KEY=              # Optional: Open-Meteo fallback if missing

# -----------------------------------------------------------------------------
# ARI system settings
# -----------------------------------------------------------------------------
# ARI_GATEWAY_PORT=3141         # Default: 3141 (loopback only)
# ARI_DAILY_BUDGET_USD=2.00     # Cost circuit breaker limit
# ARI_TIMEZONE=America/New_York # All cron runs in ET
# ARI_DB_PATH=~/.ari/databases  # SQLite WAL databases
# ARI_WORKSPACE_PATH=~/.openclaw/workspace  # Identity workspace files
